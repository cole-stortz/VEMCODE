# Root build directory only (leading slash = root only)
/build/

# App runtime files -- keep sketches folder but ignore binaries
/app/VEMCODE
/app/*.dll
/app/*.exe
/app/*.so
/app/*.dylib
/app/*.manifest
/app/*.a
/app/generic/
/app/iconengines/
/app/imageformats/
/app/networkinformation/
/app/platforms/
/app/styles/
/app/tls/
/app/translations/

# Compiled sketch artifacts inside sketches folders (all platforms)
sketches/**/*.dll
sketches/**/*.tmp.dll
sketches/**/*.so
sketches/**/*.tmp.so
sketches/**/*.dylib
sketches/**/*.tmp.dylib
app/sketches/**/*.dll
app/sketches/**/*.tmp.dll
app/sketches/**/*.so
app/sketches/**/*.tmp.so
app/sketches/**/*.dylib
app/sketches/**/*.tmp.dylib
app/sketches/**/_vb_temp.cpp

# CMake generated (root build only -- covered by /build/ above)
CMakeCache.txt
compile_commands.json

# Qt generated
*_autogen/
.qmake.stash

# IDE -- keep c_cpp_properties.json but ignore personal settings
.vscode/settings.json
.idea/
*.vcxproj
*.vcxproj.filters
*.sln
*.suo
*.user
*.directory

# OS
.DS_Store
Thumbs.db
desktop.ini

# Notes
notes/

# Settings
app/settings.ini