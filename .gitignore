# Root build directory only (leading slash = root only)
/build/

# App runtime files -- keep sketches folder but ignore binaries
/app/*.dll
/app/*.exe
/app/*.manifest
/app/*.a
/app/generic/
/app/iconengines/
/app/imageformats/
/app/networkinformation/
/app/platforms/
/app/styles/
/app/tls/
/app/translations/

# Compiled sketch artifacts inside sketches folders
sketches/**/*.dll
sketches/**/*.tmp.dll
app/sketches/**/*.dll
app/sketches/**/*.tmp.dll
app/sketches/**/_vb_temp.cpp

# Test binaries only
testfiles/*.exe
testfiles/*.dll

# CMake generated (root build only -- covered by /build/ above)
CMakeCache.txt

# Qt generated
*_autogen/
.qmake.stash

# IDE -- keep c_cpp_properties.json but ignore personal settings
.vscode/settings.json
.idea/
*.vcxproj
*.vcxproj.filters
*.sln
*.suo
*.user

# OS
.DS_Store
Thumbs.db
desktop.ini